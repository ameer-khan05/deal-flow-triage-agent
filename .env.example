# === Required ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealflow

# === LLM (optional — mock auto-selected when absent) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Data collectors (optional — collectors degrade gracefully when absent) ===
GITHUB_TOKEN=
ALCHEMY_RPC_URL=
NEYNAR_API_KEY=

# === Slack (optional — digest logged to console when absent) ===
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# === CRM (optional — sync disabled when absent) ===
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
NOTION_TOKEN=

# === Auth (optional for local dev) ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=

# === Inngest (optional for local dev — dev server auto-configures) ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === Testing ===
RUN_LIVE_TESTS=0
